# Figma / Stitch 연동용 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤, 실제 값만 로컬에서 채워 사용하세요.
# .env 는 .gitignore 에 포함되어 있으므로 GitHub 에 올라가지 않습니다.

# Figma Personal Access Token (Figma 설정 → Account → Personal access tokens)
FIGMA_PERSONAL_ACCESS_TOKEN=your_figma_token_here

# Stitch 등 다른 도구 API 키를 쓸 경우 아래처럼 추가
# STITCH_API_KEY=your_stitch_key_here
